# Frontend .env — Vite exposes vars prefixed with VITE_

# Your backend URL (in production, set to your Railway backend URL)
VITE_API_URL=http://localhost:4000

# Paystack public key (safe to expose in frontend)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# Your store name
VITE_STORE_NAME=BeatVault
